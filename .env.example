# Copy this file to .env and fill local secrets. Never commit .env.

# Yandex AI Studio. Reviewers should use their own key/folder.
YANDEX_API_KEY=<put-your-yandex-api-key-here>
YANDEX_FOLDER_ID=<put-your-folder-id-here>
YANDEX_BASE_URL=https://ai.api.cloud.yandex.net/v1
YANDEX_OCR_URL=https://ocr.api.cloud.yandex.net/ocr/v1/recognizeText
YANDEX_DATA_LOGGING=false

# Agentic RAG uses Yandex by default. OpenRouter is optional.
AGENT_LLM_PROVIDER=yandex
OPENROUTER_API_KEY=
OPENROUTER_API_KEYS=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
OPENROUTER_REASONING=true
OPENROUTER_TIMEOUT=180
OPENROUTER_MIN_INTERVAL=3.1
OPENROUTER_MAX_OUTPUT_TOKENS=3000

LLM_MODEL=gpt://<put-your-folder-id-here>/aliceai-llm/latest
EMBED_DOC_MODEL=emb://<put-your-folder-id-here>/text-embeddings-v2-doc/latest
EMBED_QUERY_MODEL=emb://<put-your-folder-id-here>/text-embeddings-v2-query/latest
EMBED_DIMENSIONS=768
VISION_MODEL=gpt://<put-your-folder-id-here>/qwen3.6-35b-a3b/latest

# Local databases created by Docker Compose.
NEO4J_PASSWORD=<strong-random-password>
NEO4J_URI=neo4j://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_DATABASE=neo4j

POSTGRES_HOST=search-db
POSTGRES_PORT=5432
POSTGRES_USER=mekg
POSTGRES_PASSWORD=<strong-random-password>
POSTGRES_DB=mekg_search
POSTGRES_POOL_MIN=1
POSTGRES_POOL_MAX=8

# Retrieval/indexing defaults.
EMBEDDING_PROVIDER=yandex
EMBEDDING_MODEL=yandex-text-embeddings-v2
IS_EMBEDDING=true
ENTITY_EMBEDDING=false
TRACK_USER_USAGE=false
AUTHENTICATION_REQUIRED=false
GRAPH_CLEANUP_MODEL=yandex_aliceai
DEFAULT_DIFFBOT_CHAT_MODEL=yandex_aliceai
EXTRACTION_PROFILE=mekg
MEKG_ARTIFACTS_DIR=/code/artifacts
MEKG_MAX_CONCURRENCY=3
MEKG_PARSE_WORKERS=4
MEKG_EMBED_WORKERS=4
MEKG_LLM_WORKERS=5
MEKG_EMBED_RATE=4
MEKG_CHUNK_WRITE_BATCH=750
MEKG_JOB_LEASE_SECONDS=300
MEKG_JOB_MAX_ATTEMPTS=3
MEKG_AGENT_POLL_SECONDS=1
MEKG_AGENT_LEASE_SECONDS=600
YANDEX_WEB_SEARCH_REGION=213
YANDEX_WEB_SEARCH_MIN_INTERVAL=1.05
WEB_REDACT_TERMS=

# Only the Q01/Q04 source presentations are included.
# Retrieval data and graph state are restored from demo-seed automatically.
CORPUS_PATH=./demo-documents

# Frontend build defaults.
VITE_BACKEND_API_URL=http://localhost:8000
VITE_REACT_APP_SOURCES=local,wiki,web
VITE_LLM_MODELS=yandex_aliceai
VITE_LLM_MODELS_PROD=yandex_aliceai
VITE_ENV=DEV
VITE_CHAT_MODES=agentic_rag,vector,graph,graph_vector,fulltext,graph_vector_fulltext
VITE_SKIP_AUTH=true
VITE_CHUNK_OVERLAP=20
VITE_TOKENS_PER_CHUNK=200
VITE_CHUNK_TO_COMBINE=1
VITE_EXTRACTION_PROFILE=mekg
